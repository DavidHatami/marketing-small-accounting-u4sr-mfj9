---
import Base from '../layouts/Base.astro';
---

<Base>
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-slate-50 to-slate-100 py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 leading-tight">
        Accounting that actually makes sense
      </h1>
      <p class="mt-6 text-xl text-gray-600 max-w-2xl mx-auto">
        We're a small team of accountants who believe you shouldn't need a finance degree to understand your own books. Clear advice, honest pricing, real people.
      </p>
      <div class="mt-10">
        <a
          href="/contact"
          class="inline-block bg-slate-900 text-white px-8 py-4 rounded-lg font-semibold text-lg hover:bg-slate-800 transition-colors"
        >
          Book a free consultation
        </a>
      </div>
    </div>
  </section>

  <!-- Value Props Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-12">
        <div class="text-center">
          <div class="w-14 h-14 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">No surprise fees</h3>
          <p class="text-gray-600">
            We quote upfront and stick to it. If something changes, we'll talk about it first—not just send you a bigger bill.
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">You'll know our names</h3>
          <p class="text-gray-600">
            No call centers, no ticket numbers. When you reach out, you talk to the same people who actually work on your account.
          </p>
        </div>

        <div class="text-center">
          <div class="w-14 h-14 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-7 h-7 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-semibold text-gray-900 mb-3">We explain everything</h3>
          <p class="text-gray-600">
            Taxes are confusing enough. We break things down in plain English so you actually understand what's happening with your money.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Secondary CTA Section -->
  <section class="py-20 bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        Ready to stop dreading tax season?
      </h2>
      <p class="text-slate-300 text-lg max-w-xl mx-auto mb-8">
        Let's have a conversation about your situation. No pressure, no jargon—just a straightforward chat about how we can help.
      </p>
      <a
        href="/contact"
        class="inline-block bg-white text-slate-900 px-8 py-4 rounded-lg font-semibold text-lg hover:bg-slate-100 transition-colors"
      >
        Get in touch
      </a>
    </div>
  </section>
</Base>
